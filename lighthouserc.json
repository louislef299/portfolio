{
  "ci": {
    "collect": {
      "staticDistDir": "./public",
      "url": [
        "/",
        "/tech/",
        "/travel/"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.6 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    }
  }
}
